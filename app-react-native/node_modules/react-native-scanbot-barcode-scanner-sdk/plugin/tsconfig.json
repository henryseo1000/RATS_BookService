{
  "compilerOptions": {
    "outDir": "build",
    "rootDir": "src",

    "lib": ["es2023"],
    "target": "es2022",
    "module": "node16",
    "moduleResolution": "node16",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true
  },
  "include": ["./src"],
}
